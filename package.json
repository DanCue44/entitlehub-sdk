{
  "name": "@entitlehub/sdk",
  "version": "0.2.0",
  "description": "EntitleHub SDK — one entitlement API across App Store, Google Play, Stripe, and web. Works in browsers, React Native, Expo, and Node.",
  "keywords": [
    "entitlehub",
    "entitlements",
    "in-app-purchase",
    "subscriptions",
    "storekit",
    "play-billing",
    "stripe"
  ],
  "homepage": "https://entitlehub.com",
  "repository": { "type": "git", "url": "git+https://github.com/DanCue44/entitlehub-sdk.git" },
  "bugs": { "url": "https://github.com/DanCue44/entitlehub-sdk/issues" },
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
